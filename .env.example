# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/feedbackboard?schema=public"

# Public app URL — used to construct absolute image URLs for uploads
# MIGRATION NOTE: Change to your production domain when deploying to AWS
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Local upload directory (defaults to public/uploads if not set)
# MIGRATION NOTE: On AWS replace filesystem uploads with S3.
# This variable won't be needed once you migrate to S3.
UPLOAD_PATH=""

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id          String    @id @default(cuid())
  title       String
  description String
  category    Category  @default(FEATURE)
  status      Status    @default(OPEN)
  votes       Int       @default(0)
  imageUrl    String?
  authorName  String
  authorEmail String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  authorName String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     String
  createdAt  DateTime @default(now())
}

enum Category {
  FEATURE
  BUG
  IMPROVEMENT
  QUESTION
}

enum Status {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}
